generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Kanal komunikacije (proširivo)
enum MessageChannel {
  MESSENGER
  INSTAGRAM
  WHATSAPP
  FACEBOOK_PAGE_FEED
  GENERIC
}

/// Sve dolazne (i po želji odlazne) poruke — univerzalni model za više izvora
model ChannelMessage {
  id                String         @id @default(cuid())
  channel           MessageChannel
  /// npr. facebook.graph, api.ingest, meta.webhook
  source            String         @default("unknown")
  /// Stabilni ključ niti (npr. pageId_psid ili thread_id iz vanjskog sustava)
  externalThreadId  String?
  /// Vanjski ID poruke (Messenger mid, itd.) — za deduplikaciju
  externalMessageId String?
  direction         String         @default("inbound")
  bodyText          String?        @db.Text
  rawPayload        Json
  createdAt         DateTime       @default(now())
  attachments       ChannelMessageAttachment[]

  @@index([channel, externalThreadId])
  @@index([channel, createdAt])
  @@unique([channel, externalMessageId])
}

model ChannelMessageAttachment {
  id               String         @id @default(cuid())
  channelMessageId String
  kind             String?
  url              String?        @db.Text
  name             String?
  ordinal          Int            @default(0)
  createdAt        DateTime       @default(now())

  message ChannelMessage @relation(fields: [channelMessageId], references: [id], onDelete: Cascade)

  @@index([channelMessageId])
  @@unique([channelMessageId, ordinal])
}

/// Verzionirani promptovi (samo jedan aktivan po slug + opcijski kanal)
model PromptTemplate {
  id          String          @id @default(cuid())
  slug        String
  name        String
  body        String          @db.Text
  version     Int
  isActive    Boolean         @default(false)
  /// null = vrijedi za sve kanale
  channel     MessageChannel?
  /// Ne primjenjuj prompt kad GET /prompts/active dobije query eventSource koji odgovara (točan string ili prefiks ako završi s *)
  excludeSources String[]      @default([])
  description String?         @db.Text
  createdAt   DateTime        @default(now())

  @@unique([slug, version])
  @@index([slug, isActive])
}

/// Automatski odgovor na čekanju odobrenja (ingest → admin odobri → slanje)
model PendingMessengerSend {
  id          String   @id @default(cuid())
  pageId      String
  recipientId String
  text        String   @db.Text
  /// PENDING | SENT | REJECTED | EXPIRED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  meta        Json?

  @@index([status, createdAt])
}

/// Ključ–vrijednost postavki aplikacije (npr. prekidač za red odobrenja ingest slanja)
model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Prikazno ime PSID-a s Graph API (Page token), za admin bez parsiranja bodyText-a
model MessengerUserProfile {
  pageId      String
  userId      String
  displayName String?
  fetchedAt   DateTime @default(now())
  fetchError  String?  @db.VarChar(500)

  @@id([pageId, userId])
  @@index([userId])
}

/// CRM oznake po korisniku (kombinacija pageId + userId/PSID)
model CrmContact {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  isLead    Boolean  @default(false)
  /// Kad je true, ingest POST /messenger/send ne šalje (automatika); admin ručno slanje i dalje radi.
  pauseAutomation Boolean @default(false)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}
