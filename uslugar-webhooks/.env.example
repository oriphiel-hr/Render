PORT=3000

# PostgreSQL (lokalno ili Render „External Database URL”)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Meta Webhooks — isti niz kao u Developer konzoli (zadani URL: GET/POST /webhook)
VERIFY_TOKEN=moj_tajni_token_123

# Meta App Secret — za provjeru potpisa POST /webhook (preporučeno u produkciji)
# FACEBOOK_APP_SECRET=

# Više Meta aplikacija na istom servisu — Callback https://host/webhook/<profil>
# META_WEBHOOK_PROFILES=instant-game
# Za profil "instant-game": META_INSTANT_GAME_VERIFY_TOKEN=...  META_INSTANT_GAME_APP_SECRET=...
# Opcionalno: vlastita baza za poruke s tog webhooka (inače koristi DATABASE_URL)
# META_INSTANT_GAME_DATABASE_URL=postgresql://...

# Za POST /api/v1/messages i GET /api/v1/prompts/active/:slug (header X-Ingest-Key ili Authorization: Bearer)
INGEST_API_KEY=izmijeni_slucajnim_nizom
