# Sudski registar API (OAuth2 client credentials, Basic auth)
# Registracija: https://sudreg-data.gov.hr — potvrdi e-mail i klikni Aktivacija.
# Točke u ID/secretu (npr. xxx.yyy) su dio vrijednosti — ne uklanjaj ih.
SUDREG_CLIENT_ID=
SUDREG_CLIENT_SECRET=
SUDREG_TOKEN_URL=https://sudreg-data.gov.hr/api/oauth/token
# Opcionalno (default: https://sudreg-data.gov.hr/api/javni)
# SUDREG_JAVNI_BASE_URL=https://sudreg-data.gov.hr/api/javni
# Mreža prema Sudregu (po zahtjevu): timeout ms, broj ponovnih pokušaja na "fetch failed"
# SUDREG_FETCH_TIMEOUT_MS=120000
# SUDREG_FETCH_RETRIES=3

# Staging na disk (snapshots/{id}/, diffs/{from}_to_{to}/)
# Lokalno: ./data — na Renderu: persistent disk npr. /var/data
# SUDREG_DATA_DIR=./data

# PostgreSQL (Render) — nakon spremanja JSON na disk, sync u bazu (automatski ako je postavljen)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
