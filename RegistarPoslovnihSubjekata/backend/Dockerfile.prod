# Root Directory (Render): RegistarPoslovnihSubjekata/backend
# Dockerfile Path: Dockerfile.prod   (relativno na backend — bez dodatnog prefiksa)
# Docker Build Context: prazno ili .
FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
COPY prisma ./prisma
RUN npm ci

COPY src ./src
COPY public ./public
RUN npx prisma generate

ENV NODE_ENV=production
EXPOSE 3000

CMD ["node", "src/server.js"]
