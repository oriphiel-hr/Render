# Root Directory (Render): RegistarPoslovnihSubjekata/backend
# Dockerfile Path: Dockerfile.prod   (relativno na backend — bez dodatnog prefiksa)
# Docker Build Context: prazno ili .
FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY src ./src
COPY public ./public

ENV NODE_ENV=production
EXPOSE 3000

CMD ["node", "src/server.js"]
