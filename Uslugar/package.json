{
  "name": "uslugar-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "mobile",
    "packages/*",
    "tests"
  ],
  "scripts": {
    "build:web": "npm run build --workspace=frontend",
    "build:mobile": "npm run typecheck --workspace=mobile",
    "build:shared": "npm run build --workspace=@uslugar/shared",
    "dev:web": "npm run dev --workspace=frontend",
    "dev:mobile": "npm run start --workspace=mobile"
  }
}
