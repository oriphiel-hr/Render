generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProfileAvailability {
  AVAILABLE
  FOCUSED_CONTACT
  PAUSED
}

enum PairStatus {
  ACTIVE
  CLOSED
}

enum ContactStatus {
  PENDING
  ACCEPTED
  DECLINED
  AUTO_CLOSED
}

enum UserRole {
  USER
  ADMIN
}

enum ModerationReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum PaymentProvider {
  STRIPE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model UserProfile {
  id            String              @id @default(cuid())
  email         String              @unique
  displayName   String
  age           Int
  dateOfBirth   DateTime
  city          String
  bio           String?
  identity      String              @default("OTHER")
  profileType   String              @default("INDIVIDUAL")
  seekingIdentities Json
  seekingProfileTypes Json
  intents       Json
  availability  ProfileAvailability @default(AVAILABLE)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  account       UserAccount?
}

model EngagedPair {
  id           String     @id @default(cuid())
  userAId      String
  userBId      String
  sourceContactId String?
  status       PairStatus @default(ACTIVE)
  startedAt    DateTime   @default(now())
  endedAt      DateTime?
  closeReason  String?

  @@index([status, startedAt])
  @@index([userAId, userBId, status])
}

model MatchContact {
  id            String        @id @default(cuid())
  requesterId   String
  targetId      String
  status        ContactStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([requesterId, status, createdAt])
  @@index([targetId, status, createdAt])
}

model UserAccount {
  id              String   @id @default(cuid())
  profileId       String   @unique
  passwordHash    String
  role            UserRole @default(USER)
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profile         UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model EmailVerificationCode {
  id          String   @id @default(cuid())
  email       String
  code        String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([email, createdAt])
  @@index([email, code, expiresAt])
}

model UserBlock {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  reason      String?
  createdAt   DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId, createdAt])
}

model UserReport {
  id          String                 @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      String
  details     String?
  status      ModerationReportStatus @default(OPEN)
  priority    Int                    @default(1)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([status, priority, createdAt])
  @@index([reportedId, createdAt])
}

model UserRating {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())

  @@index([toUserId, createdAt])
  @@index([fromUserId, createdAt])
}

model FairnessConfigChange {
  id             String   @id @default(cuid())
  changedByUserId String?
  oldDailyLimit  Int
  newDailyLimit  Int
  reason         String
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model PaymentOrder {
  id                  String         @id @default(cuid())
  userProfileId       String
  provider            PaymentProvider
  status              PaymentStatus  @default(PENDING)
  amountCents         Int
  currency            String         @default("EUR")
  description         String
  stripeSessionId     String?
  bankTransferReference String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([userProfileId, createdAt])
  @@index([status, createdAt])
}
